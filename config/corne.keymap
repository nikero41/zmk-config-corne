#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

#define BASE 0
#define SYMBOLS 1
#define MISC 2
#define FUNCTIONS 3
#define LOL 4

#define COMBO_TIMEOUT 50

/* Base layer positions used by combos: top row 3=E 4=R 7=U 8=I; home row 15=D 16=F 18=H 19=J; bottom row 27=C 28=V 30=N 31=M 32=, */
#define POS_E 3
#define POS_R 4
#define POS_U 7
#define POS_I 8
#define POS_D 15
#define POS_F 16
#define POS_H 18
#define POS_J 19
#define POS_C 27
#define POS_V 28
#define POS_N 30
#define POS_M 31
#define POS_COMMA 32

/* LOL layer positions used by combos: top row 1=N1; home row 17=T */
#define LOL_POS_N1 1
#define LOL_POS_T 17

&caps_word {
    continue-list = <UNDERSCORE BACKSPACE DELETE MINUS>;
};

/ {
    behaviors {
        ht: hold_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <220>;
            quick-tap-ms = <200>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
        };

        captap: caps_lock_tap {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&caps_word>, <&kp CAPSLOCK>;
        };

        symbols_double_tap_toggle: behavior_symbols_double_tap_toggle {
            compatible = "zmk,behavior-tap-dance";
            label = "symbols-double-tap-toggle";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&none>, <&tog SYMBOLS>;
        };

        symbols_hold_double_tap_toggle: behavior_symbols_hold_double_tap_toggle {
            compatible = "zmk,behavior-hold-tap";
            label = "symbols-hold-double-tap-toggle";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&mo>, <&symbols_double_tap_toggle>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        tri {
            if-layers = <SYMBOLS MISC>;
            then-layer = <FUNCTIONS>;
        };
    };

    combos {
        compatible = "zmk,combos";

        combo_left_brace {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_E POS_D>;
            bindings = <&kp LEFT_BRACE>;
            layers = <BASE>;
        };

        combo_right_brace {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_R POS_F>;
            bindings = <&kp RIGHT_BRACE>;
            layers = <BASE>;
        };

        combo_left_paren {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_D POS_C>;
            bindings = <&kp LEFT_PARENTHESIS>;
            layers = <BASE>;
        };

        combo_right_paren {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_F POS_V>;
            bindings = <&kp RIGHT_PARENTHESIS>;
            layers = <BASE>;
        };

        combo_ampersand_home {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_H POS_J>;
            bindings = <&kp AMPS>;
            layers = <BASE>;
        };

        combo_minus {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_U POS_I>;
            bindings = <&kp MINUS>;
            layers = <BASE>;
        };

        combo_underscore_bottom {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <POS_M POS_COMMA>;
            bindings = <&kp UNDERSCORE>;
            layers = <BASE>;
        };

        combo_lol_n1_t_p {
            timeout-ms = <COMBO_TIMEOUT>;
            key-positions = <LOL_POS_N1 LOL_POS_T>;
            bindings = <&kp P>;
            layers = <LOL>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base {
            display-name = "base";
            bindings = <
//    в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
//    в”Ӯ tab в”Ӯ     Q      в”Ӯ     W      в”Ӯ     E      в”Ӯ  R   в”Ӯ     T      в”Ӯ   в”Ӯ     Y      в”Ӯ                          U                          в”Ӯ    I    в”Ӯ     O      в”Ӯ     P     в”Ӯ     \      в”Ӯ
//    в”ңв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө   в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
